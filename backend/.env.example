# Backend runtime
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000

# PostgreSQL
POSTGRES_DB=github_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Production database, for Render/Neon use a JDBC URL such as:
# jdbc:postgresql://HOST:5432/DATABASE?sslmode=require
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# GitHub API
GITHUB_TOKEN=your_github_token_here
GITHUB_CACHE_TTL_SECONDS=300

# JWT
JWT_SECRET=change_this_to_a_long_secure_secret_key_for_dev
JWT_EXPIRATION_MS=86400000

# Optional email notifications
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_FROM=no-reply@repolens.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
